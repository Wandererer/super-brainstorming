{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Super Brainstorming Frame",
  "description": "Structured input that skips Phase 1 (Framing). Produced by the frame builder sub-skill or written by hand.",
  "type": "object",
  "required": [
    "frame"
  ],
  "properties": {
    "frame": {
      "type": "object",
      "required": [
        "topic",
        "hmw"
      ],
      "properties": {
        "topic": {
          "type": "string",
          "description": "Original topic as the user phrased it"
        },
        "hmw": {
          "type": "string",
          "description": "How Might We statement — target + context + desired change, NO baked-in solution"
        },
        "goal_type": {
          "type": "string",
          "enum": [
            "new_product",
            "feature",
            "growth",
            "pivot",
            "other"
          ],
          "default": "new_product"
        },
        "context": {
          "type": "string",
          "description": "Why this brainstorm matters now"
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "What the user already has — skills, audience, codebase, data"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Real-world limits — team size, runway, deadline. Feasibility is scored against these."
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "What makes this session a success — checkable at session end"
        },
        "anti_goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "What is explicitly NOT wanted — divergence agents treat these as off-limits"
        }
      }
    },
    "divergence": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "creative",
            "research_first"
          ],
          "default": "creative",
          "description": "creative = thinking-lens divergence (default). research_first = evidence mining across many sources THEN evidence-grounded ideation (research → brainstorming); every idea card must cite evidence_ids."
        },
        "miners": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "review_miner",
              "community_miner",
              "competitor_gap_miner",
              "trend_miner",
              "market_data_miner",
              "solution_saturation_miner"
            ]
          },
          "description": "research_first mode: which evidence miners to deploy. If omitted, all 6 (incl. solution_saturation_miner — maps existing products per niche)."
        },
        "evidence_per_miner": {
          "type": "integer",
          "minimum": 4,
          "maximum": 15,
          "default": 8,
          "description": "research_first mode: target evidence cards per miner"
        },
        "lens_count": {
          "type": "integer",
          "minimum": 3,
          "maximum": 10,
          "default": 6
        },
        "lenses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "first_principles",
              "contrarian",
              "cross_industry",
              "user_pain_archaeologist",
              "constraint_flip",
              "future_back",
              "scamper",
              "resource_extremes",
              "adjacent_possible",
              "anti_persona",
              "random_stimulus",
              "villain",
              "ten_x",
              "pain_to_product",
              "gap_wedge",
              "trend_collision"
            ]
          },
          "description": "Explicit lens lineup. creative mode: goal-type default lineup if omitted. research_first mode: the 3 synthesis lenses (pain_to_product, gap_wedge, trend_collision) are the default."
        },
        "ideas_per_lens": {
          "type": "integer",
          "minimum": 3,
          "maximum": 12,
          "default": 6
        },
        "wildness_appetite": {
          "type": "string",
          "enum": [
            "safe",
            "balanced",
            "wild"
          ],
          "default": "balanced"
        },
        "wildcard": {
          "type": "boolean",
          "default": true,
          "description": "creative mode: include wildcard lens(es) per wildness_appetite"
        }
      }
    },
    "convergence": {
      "type": "object",
      "properties": {
        "shortlist_size": {
          "type": "integer",
          "minimum": 3,
          "maximum": 10,
          "default": 5
        },
        "min_judges": {
          "type": "integer",
          "minimum": 2,
          "maximum": 3,
          "default": 2
        },
        "min_ideas": {
          "type": "integer",
          "minimum": 5,
          "default": 15,
          "description": "Gate threshold — fewer surviving candidates than this is a process violation (exit 1)"
        },
        "min_hybrids": {
          "type": "integer",
          "minimum": 0,
          "default": 1,
          "description": "Gate threshold — cross-pollination proof"
        },
        "min_lenses": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Gate threshold — surviving candidates must span at least this many distinct lenses; fewer is a process violation (exit 1)"
        },
        "min_evidence": {
          "type": "integer",
          "minimum": 5,
          "default": 15,
          "description": "research_first mode gate — fewer evidence cards than this means mining was too thin (exit 1)"
        },
        "min_miners": {
          "type": "integer",
          "minimum": 2,
          "default": 3,
          "description": "research_first mode gate — evidence must come from at least this many distinct miners (multi-modal sweep proof)"
        },
        "min_evidence_refs": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "research_first mode gate — every candidate idea must cite at least this many evidence_ids (exit 1 otherwise)"
        },
        "scoring_weights": {
          "type": "object",
          "description": "Per-axis weights. Normalized to sum 1 by validate_ideas.py.",
          "properties": {
            "novelty": {
              "type": "number",
              "minimum": 0
            },
            "impact": {
              "type": "number",
              "minimum": 0
            },
            "feasibility": {
              "type": "number",
              "minimum": 0
            },
            "fit": {
              "type": "number",
              "minimum": 0
            },
            "timing": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "brief_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "default": 2,
          "description": "How many shortlist concepts to deep-dive (user picks the actual ones in Phase 6)"
        },
        "handoff": {
          "type": "string",
          "enum": [
            "insane-research",
            "spec",
            "none"
          ],
          "default": "insane-research"
        },
        "language": {
          "type": "string",
          "default": "ko",
          "description": "Language of final deliverables"
        }
      }
    }
  }
}
